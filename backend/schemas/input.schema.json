{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://studytrail.app/schemas/input.schema.json",
  "title": "StudyPlanRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timezone",
    "week_start_date",
    "daily_hours",
    "subjects",
    "tasks",
    "study_style"
  ],
  "properties": {
    "timezone": {
      "type": "string",
      "description": "IANA timezone, e.g. Europe/Belgrade"
    },
    "week_start_date": {
      "type": "string",
      "format": "date",
      "description": "Start date of planning week (YYYY-MM-DD)"
    },
    "daily_hours": {
      "type": "object",
      "description": "Available study hours for each weekday",
      "additionalProperties": false,
      "required": [
        "monday",
        "tuesday",
        "wednesday",
        "thursday",
        "friday",
        "saturday",
        "sunday"
      ],
      "properties": {
        "monday": { "type": "number", "minimum": 0, "maximum": 24 },
        "tuesday": { "type": "number", "minimum": 0, "maximum": 24 },
        "wednesday": { "type": "number", "minimum": 0, "maximum": 24 },
        "thursday": { "type": "number", "minimum": 0, "maximum": 24 },
        "friday": { "type": "number", "minimum": 0, "maximum": 24 },
        "saturday": { "type": "number", "minimum": 0, "maximum": 24 },
        "sunday": { "type": "number", "minimum": 0, "maximum": 24 }
      }
    },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "importance"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "importance": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "1=low priority, 5=high priority"
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subject",
          "title",
          "due_date",
          "estimated_total_minutes",
          "task_type"
        ],
        "properties": {
          "subject": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "topic": { "type": "string" },
          "due_date": { "type": "string", "format": "date" },
          "estimated_total_minutes": { "type": "integer", "minimum": 30 },
          "task_type": {
            "type": "string",
            "enum": ["exam", "assignment", "project", "quiz"]
          }
        }
      }
    },
    "study_style": {
      "type": "string",
      "enum": ["more_practice", "more_theory", "balanced"]
    },
    "max_session_minutes": {
      "type": "integer",
      "minimum": 30,
      "maximum": 180,
      "default": 90
    }
  }
}
